# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# App URL (must match domain in WalletConnect project settings)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vesting contract address on BSC
NEXT_PUBLIC_VESTING_CONTRACT_ADDRESS=0x3dF9D9c76326D019CABFC3e569E335d0E2A94443

# SNACK token contract address on BSC
NEXT_PUBLIC_SNACK_TOKEN_ADDRESS=0x94a1a356d4e67a3803bdfaa85c8cba5bc57fd988

# BSC RPC URL (public, no key required for <100 users)
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org/